      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "elasticsearch_cluster_health_status{color=\"green\"} * 2 or elasticsearch_cluster_health_status{color=\"yellow\"} * 1 or elasticsearch_cluster_health_status{color=\"red\"} * 0",
          "legendFormat": "status",
          "refId": "A"
        }
      ]
